{
  "compilerOptions": {
    "allowJs": true,    
    "checkJs": true,
    "noEmit": true,
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

  },
  "include": ["src/**/*.js", "src/**/*.d.js"]
}
